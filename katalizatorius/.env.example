# Copy to .env and fill in. .env is gitignored — keep it that way.

# Required. Helius, QuickNode, Triton, or any Solana JSON-RPC endpoint.
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Optional. If set, the engine watches this bonding curve directly.
# If omitted, you'll be prompted for a mint address and the PDA is derived from it.
PDA_ADDRESS=

# Optional. If omitted, you'll be prompted at startup.
# Telegram bot token from @BotFather, and your numeric chat id from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
